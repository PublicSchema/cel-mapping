{
  "name": "ctx-timezone",
  "mapping": {
    "version": "0.2",
    "id": "ctx-timezone",
    "property_mappings": [
      {
        "id": "tz-field",
        "source": "/name",
        "target": "/timezone_used",
        "formula": {
          "to_target": {
            "expression": "ctx.timezone"
          }
        }
      }
    ]
  },
  "direction": "to_target",
  "source_data": {
    "name": "Ada"
  },
  "ctx": {
    "timezone": "America/New_York"
  },
  "options": {
    "privacy": "authoring",
    "errors_mode": "collect"
  },
  "expected": {
    "ok": true,
    "output": { "timezone_used": "America/New_York" },
    "errors_count": 0,
    "warnings_count": 0,
    "log_statuses": ["applied"]
  }
}
